{
  "name": "mail-processor",
  "version": "0.1.0",
  "description": "Standalone Mail-Triage/Routing/Processing pipeline.",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "mail-processor": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "shadow": "node dist/cli.js --mode=shadow",
    "run": "node dist/cli.js --mode=run",
    "discover-projects": "node dist/cli.js --discover-projects",
    "run:shadow": "node scripts/run-shadow.mjs",
    "run:routing": "node scripts/run-run.mjs",
    "create:account-proxy": "node scripts/create-himalaya-account-proxy.mjs",
    "apply:suggestions": "node scripts/apply-project-suggestions.mjs",
    "check:skill-runners": "node scripts/check-skill-runners.mjs",
    "check:sync": "node scripts/check-sync.mjs",
    "check": "tsc -p tsconfig.json --noEmit && npm run check:skill-runners"
  },
  "keywords": [
    "mail",
    "triage",
    "routing",
    "imap",
    "openclaw"
  ],
  "author": "Martin Mayr",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  }
}

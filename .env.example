# mail-processor — .env.example
#
# Ziel: Mail-Triage (Extraktion + Klassifizierung) und sicheres Routing (COPY-only) via IMAP/Himalaya.
# Diese Datei ist ein Beispiel. Echte Secrets gehören NICHT ins Repo.

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
MAIL_PROCESSOR_RUN_ID=

# Workspace / data dirs (defaults shown)
MAIL_PROCESSOR_DATA_DIR=./data/mail-routing
MAIL_PROCESSOR_STATE_FILE=./data/mail-routing/state.jsonl
MAIL_PROCESSOR_MSGS_DIR=./data/mail-routing/msgs
MAIL_PROCESSOR_SUGGESTIONS_FILE=./data/mail-routing/memory_suggestions.jsonl

# Concurrency / locking (empfohlen: Single runner)
MAIL_PROCESSOR_LOCK_FILE=./data/mail-routing/router.lock
MAIL_PROCESSOR_LOCK_TTL_SECONDS=900

# -----------------------------------------------------------------------------
# Mail access (via Himalaya)
# -----------------------------------------------------------------------------
# Himalaya account name (as configured in ~/.config/himalaya/config.toml)
HIMALAYA_ACCOUNT=

# Source folder to scan (IMAP folder name)
MAIL_SOURCE_FOLDER=INBOX

# Optional: only consider the newest N messages per run
MAIL_FETCH_LIMIT=50

# Optional: ignore messages older than X days (safety)
MAIL_MAX_AGE_DAYS=30

# Mark as seen after successful processing (COPY + state write)
MAIL_SET_SEEN_AFTER_SUCCESS=false

# Reply bucket folder (additional COPY target when needsReply=true)
MAIL_NEEDS_REPLY_FOLDER=Projekte/_Needs-Reply

# -----------------------------------------------------------------------------
# Project knowledge base (routing targets)
# -----------------------------------------------------------------------------
# Source-of-truth project catalog (must include mailbox_folder per project)
PROJECTS_JSON_PATH=./memory/references/projects/projects.json

# Matching thresholds
PROJECT_MATCH_THRESHOLD=0.65
PROJECT_MATCH_DELTA=0.15
NEEDS_REPLY_THRESHOLD=0.70

# Hard exclusions (comma-separated substrings/domains; evaluated after normalization)
# Example: no-reply,do-not-reply,newsletter
NEEDS_REPLY_NEGATIVE_HINTS=no-reply,do-not-reply,newsletter,automatische antwort,autoreply

# -----------------------------------------------------------------------------
# LLM extraction (extract-llm.mjs)
# -----------------------------------------------------------------------------
# OpenAI-compatible endpoint settings (can be OpenClaw provider gateway, local proxy, etc.)
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Extraction behavior
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=800
LLM_TIMEOUT_MS=60000

# Language hints (affects prompt + normalization)
LLM_PREFERRED_LANGUAGE=de

# -----------------------------------------------------------------------------
# Routing actions (COPY-only)
# -----------------------------------------------------------------------------
# Safety switch: if false, never execute COPY; only log decisions (shadow mode)
MAIL_ROUTING_ENABLED=false

# If true, write debug artefacts (full extracts) to msgs dir.
# Consider retention policy + redaction if you enable this in production.
MAIL_WRITE_DEBUG_MSGS=true

# Retention (for debug artefacts)
MAIL_DEBUG_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Retry / backoff
# -----------------------------------------------------------------------------
LLM_RETRY_MAX=2
LLM_RETRY_BACKOFF_MS=750
IMAP_RETRY_MAX=2
IMAP_RETRY_BACKOFF_MS=750

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=text

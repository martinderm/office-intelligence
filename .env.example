# mail-processor — .env.example
#
# Hinweis: Maßgeblich sind die Defaults in src/env.ts.
# Diese Datei zeigt nur die aktuell unterstützten Variablen.

# -----------------------------------------------------------------------------
# Core runtime
# -----------------------------------------------------------------------------
NODE_ENV=development
MAIL_PROCESSOR_RUN_ID=

# Agent workspace root (required by skills/mail-processor/scripts/run-discover-projects.mjs)
AGENT_WORKSPACE_ROOT=

MAIL_PROCESSOR_DATA_DIR=./data/mail-processor
MAIL_PROCESSOR_STATE_FILE=./data/mail-processor/state.jsonl
MAIL_PROCESSOR_MSGS_DIR=./data/mail-processor/msgs
MAIL_PROCESSOR_SUGGESTIONS_FILE=./data/mail-processor/memory_suggestions.jsonl
MAIL_PROCESSOR_CAPABILITIES_DIR=./data/mail-processor/capabilities
PENDING_ACTIONS_FILE=./data/mail-processor/pending-actions.json
ACTION_LOG_DIR=./data/mail-processor/logs/actions

MAIL_PROCESSOR_LOCK_FILE=./data/mail-processor/router.lock
MAIL_PROCESSOR_LOCK_TTL_SECONDS=900

# -----------------------------------------------------------------------------
# mail-desk / final-index (optional override)
# -----------------------------------------------------------------------------
# Default remains workspace-relative: ./data/mail-desk/final-location-index.json
# Use this only if mail-desk data should live elsewhere.
MAIL_DESK_DATA_DIR=./data/mail-desk

# -----------------------------------------------------------------------------
# Mail access (via Himalaya)
# -----------------------------------------------------------------------------
# Beispielwerte:
# - ./skills/himalaya-gate/scripts/himalaya-gate.exe
# - node ./scripts/himalaya-account-proxy.mjs
# - mock
HIMALAYA_COMMAND=himalaya
MAIL_SOURCE_FOLDER=INBOX
MAIL_FETCH_LIMIT=20
MAIL_SCAN_MODE=auto
MAIL_ENVELOPE_PAGE_SIZE=100
MAIL_SELECT_MAX_SCAN_PAGES=10
MAIL_CURSOR_FILE=./data/mail-processor/cursor.json
MAIL_INTER_MESSAGE_DELAY_MS=0
MAIL_INTER_MESSAGE_JITTER_MS=0
MAIL_MESSAGE_READ_TIMEOUT_MS=30000
MAIL_MESSAGE_READ_RETRIES=1
MAIL_MESSAGE_READ_RETRY_BACKOFF_MS=1500

# -----------------------------------------------------------------------------
# Project knowledge base
# -----------------------------------------------------------------------------
PROJECTS_JSON_PATH=./memory/references/projects/projects.json
TOPICS_JSON_PATH=./memory/references/topics/topics.json
PROJECT_MATCH_THRESHOLD=0.65
NEEDS_REPLY_THRESHOLD=0.70
NEEDS_REPLY_NEGATIVE_HINTS=no-reply,do-not-reply,newsletter,automatische antwort,autoreply

# -----------------------------------------------------------------------------
# LLM extraction
# -----------------------------------------------------------------------------
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_ENABLED=true
LLM_TIMEOUT_MS=60000
LLM_PROMPT_PATH=


# -----------------------------------------------------------------------------
# Sanitizing / preprocessing
# -----------------------------------------------------------------------------
MAIL_SANITIZE_ENABLED=true
MAIL_SANITIZE_MODE=balanced
MAIL_STRIP_TRACKING_PARAMS=true
MAIL_NEWSLETTER_FOOTER_TRIM=true
MAIL_HTML_MAX_CURRENT=5000
MAIL_HTML_MAX_QUOTED=1200

# -----------------------------------------------------------------------------
# Routing actions
# -----------------------------------------------------------------------------
MAIL_ROUTING_ENABLED=false
MAIL_ROUTE_ACTION=auto
# BOKU/GroupWise: copy behaves like move; use acts_like_move there.
MAIL_COPY_SEMANTICS=normal
MAIL_ROUTE_STRICT=false
MAIL_USE_UIDPLUS=true
MAIL_DEBUG_RETENTION_DAYS=30

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# Agent skill runners use existing dist/cli.js by default.
# Set true only for explicit dev/test runs that should rebuild first.
MAIL_PROCESSOR_BUILD_BEFORE_RUN=false

# Health checks (skills/mail-processor/scripts/check-health.mjs)
HEALTH_STALE_LOCK_MAX_SECONDS=300
HEALTH_RECENT_WINDOW_MINUTES=60
HEALTH_MAX_TLS_ERRORS=3
HEALTH_ORPHAN_RUN_MAX_AGE_SECONDS=900
